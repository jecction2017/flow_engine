# Copy to .env and adjust. Used by:
# - flow-db / python-dotenv
# - Cursor MCP servers `mysql-read` / `mysql-dml` (.cursor/mcp.json → envFile)

# Option A: single URL (SQLAlchemy / flow-db; MCP 仍可用 MYSQL_* 或同一 DATABASE_URL)
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/flow_engine

# Option B: discrete fields (password may be empty on local root)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=flow_engine

# 设为 1/true 时，MCP ``mysql-dml`` 的 ``dml_execute`` 将拒绝执行（应急关闭写能力）
# MYSQL_DML_DISABLE=1

# 只读 MCP（``mysql-read``）：``select_execute`` 最多返回行数（默认 2000，最大 50000）
# MYSQL_READ_MAX_ROWS=2000
# 设为 1/true 时，MCP ``mysql-read`` 将拒绝执行（应急关闭读能力）
# MYSQL_READ_DISABLE=1
