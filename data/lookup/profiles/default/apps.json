{
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "应用信息表",
    "description": "存储系统内所有接入应用的基础信息",
    "required": [
      "appid",
      "appname",
      "owner"
    ],
    "properties": {
      "appid": {
        "type": "string",
        "description": "应用唯一标识",
        "minLength": 3,
        "maxLength": 32,
        "pattern": "^[a-z0-9-]+$"
      },
      "appname": {
        "type": "string",
        "description": "应用显示名称",
        "minLength": 1,
        "maxLength": 64
      },
      "desc": {
        "type": "string",
        "description": "应用描述信息",
        "maxLength": 255
      },
      "owner": {
        "type": "string",
        "description": "应用负责人（通常为域账号或工号）",
        "minLength": 1
      },
      "status": {
        "type": "integer",
        "description": "应用状态: 1-正常, 0-停用",
        "enum": [
          0,
          1
        ],
        "default": 1
      },
      "tags": {
        "type": "array",
        "description": "应用标签",
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      }
    },
    "additionalProperties": false
  },
  "rows": [
    {
      "appid": "demo-001",
      "appname": "演示应用",
      "desc": "lookup 示例数据",
      "owner": "platform",
      "status": 1,
      "tags": ["demo", "test"]
    }
  ]
}